{
  "name": "ez-php/ai",
  "version": "1.10.0",
  "description": "Multi-provider AI client for ez-php — unified driver-based abstraction over OpenAI, Anthropic, Gemini, and Mistral",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Andreas Uretschnig",
      "email": "andreas.uretschnig@gmail.com"
    }
  ],
  "keywords": ["ai", "openai", "anthropic", "claude", "gemini", "mistral", "llm", "gpt", "php", "ez-php"],
  "homepage": "https://github.com/ez-php/ai",
  "support": {
    "issues": "https://github.com/ez-php/ai/issues",
    "source": "https://github.com/ez-php/ai"
  },
  "require": {
    "php": "^8.5",
    "ez-php/http-client": "^1.0",
    "ez-php/contracts": "^1.0"
  },
  "require-dev": {
    "ez-php/docker": "^1.0",
    "phpunit/phpunit": "^13.0",
    "phpstan/phpstan": "^2.1",
    "friendsofphp/php-cs-fixer": "^3.94",
    "phpstan/phpstan-strict-rules": "^2.0",
    "phpstan/phpstan-deprecation-rules": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "EzPhp\\Ai\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\Ai\\": "tests/"
    }
  },
  "scripts": {
    "cs": "php-cs-fixer fix",
    "analyse": "phpstan analyse",
    "test": "phpunit",
    "full": "composer analyse && composer cs && composer test"
  }
}
